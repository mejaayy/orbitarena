# ─── Database ────────────────────────────────────────────────────────────────
# Railway PostgreSQL plugin sets this automatically when you add the plugin.
# For local dev: postgresql://user:password@localhost:5432/orbitarena
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Solana / Stake Mode ─────────────────────────────────────────────────────
# Public key of the platform wallet that receives entry fees and pays out prizes.
PLATFORM_WALLET_ADDRESS=your_platform_wallet_public_key

# Private key of the platform wallet (base58-encoded string — NOT a JSON array).
# Used server-side only to sign USDC withdrawal transactions.
PLATFORM_WALLET_PRIVATE_KEY=your_platform_wallet_private_key_base58

# Reliable Solana mainnet RPC endpoint.
# Free public endpoint works but may throttle under load.
# Recommended: Helius (https://helius.dev) or QuickNode.
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# ─── Server ──────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — do not set this manually in Railway.
# PORT=5000
